# =========================
# Database
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dockie_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/dockie_copilot
SYNC_DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/dockie_copilot

# Vector / knowledge
KNOWLEDGE_VECTOR_BACKEND=pgvector

# =========================
# App
# =========================
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# =========================
# Agent runtime
# =========================
ADK_APP_NAME=dockie-copilot
ADK_USER_ID=local-user
ADK_MODEL=gemini-3-flash-preview

ADK_SESSION_BACKEND=database
ADK_SESSION_DB_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/dockie_copilot

# =========================
# API Keys
# =========================
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key
AISSTREAM_API_KEY=your_aisstream_api_key

# =========================
# Source URLs
# =========================
SALLAUM_SCHEDULE_URL=https://sallaumlines.com/schedules/us-to-west-africa/
GRIMALDI_SCHEDULE_URL=https://www.gnet.grimaldi-eservice.com/webdata/Published_Sched_Fleetpos/sched_nw.htm
NIGERIAN_PORTS_URL=https://shippos.nigerianports.gov.ng/

# =========================
# Source refresh controls
# =========================
SOURCE_FIXTURES_ENABLED=true
SOURCE_AISSTREAM_ENABLED=true
SOURCE_SALLAUM_ENABLED=true
SOURCE_GRIMALDI_ENABLED=true
SOURCE_NIGERIAN_PORTS_ENABLED=true
SOURCE_HISTORICAL_AIS_ENABLED=true
SOURCE_OFFICIAL_SANCTIONS_ENABLED=true
SOURCE_FETCH_DEBUG=true

# =========================
# Cache
# =========================
CACHE_ENABLED=true
REDIS_URL=rediss://default:your_upstash_token@your_upstash_host:6379
CACHE_PREFIX=dockie
CACHE_LIST_SHIPMENTS_TTL_SECONDS=30
CACHE_SHIPMENT_STATUS_TTL_SECONDS=30
CACHE_SHIPMENT_HISTORY_TTL_SECONDS=60
CACHE_SOURCE_HEALTH_TTL_SECONDS=60

# =========================
# Supabase auth + email integration
# =========================
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_EDGE_FUNCTION_KEY=your_supabase_edge_function_key
SUPABASE_EMAIL_FUNCTION_NAME=send-standby-email

# =========================
# Standby worker
# =========================
STANDBY_WORKER_POLL_SECONDS=10
STANDBY_WORKER_BATCH_SIZE=25
STANDBY_DEFAULT_COOLDOWN_SECONDS=600
STANDBY_DIGEST_SEND_HOUR_LOCAL=8