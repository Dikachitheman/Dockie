# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=dockie_copilot
POSTGRES_USER=dockie
POSTGRES_PASSWORD=dockie_secret

# DATABASE_URL=postgresql+asyncpg://dockie:dockie_secret@db:5432/dockie_copilot
# SYNC_DATABASE_URL=postgresql://dockie:dockie_secret@db:5432/dockie_copilot

DATABASE_URL=postgresql+asyncpg://dockie:dockie_secret@localhost:5432/dockie_copilot
SYNC_DATABASE_URL=postgresql://dockie:dockie_secret@localhost:5432/dockie_copilot


# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# External APIs (optional)
AISSTREAM_API_KEY=
GOOGLE_API_KEY=
SOURCE_FETCH_DEBUG=false
SALLAUM_SCHEDULE_URL=
GRIMALDI_SCHEDULE_URL=
NIGERIAN_PORTS_URL=

# Source refresh controls
SOURCE_FIXTURES_ENABLED=true
SOURCE_AISSTREAM_ENABLED=true
SOURCE_SALLAUM_ENABLED=true
SOURCE_GRIMALDI_ENABLED=true
SOURCE_NIGERIAN_PORTS_ENABLED=true
SOURCE_HISTORICAL_AIS_ENABLED=true
SOURCE_OFFICIAL_SANCTIONS_ENABLED=true

# Agent runtime
ADK_APP_NAME=dockie-copilot
ADK_USER_ID=local-user
ADK_MODEL=gemini-3-flash-preview
ADK_SESSION_BACKEND=database
ADK_SESSION_DB_URL=postgresql+asyncpg://dockie:dockie_secret@localhost:5432/dockie_copilot

# Cache
CACHE_ENABLED=true
REDIS_URL=rediss://default:your-upstash-token@your-upstash-host:6379
CACHE_PREFIX=dockie
CACHE_LIST_SHIPMENTS_TTL_SECONDS=30
CACHE_SHIPMENT_STATUS_TTL_SECONDS=30
CACHE_SHIPMENT_HISTORY_TTL_SECONDS=60
CACHE_SOURCE_HEALTH_TTL_SECONDS=60

# Supabase standby email integration
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_EDGE_FUNCTION_KEY=
SUPABASE_EMAIL_FUNCTION_NAME=send-standby-email

# Standby worker
STANDBY_WORKER_POLL_SECONDS=10
STANDBY_WORKER_BATCH_SIZE=25
STANDBY_DEFAULT_COOLDOWN_SECONDS=600
STANDBY_DIGEST_SEND_HOUR_LOCAL=8
