# PostgreSQL with PostGIS + pgvector for local Docker Compose.
#
# Keep the Postgres major (15 vs 16) aligned with existing data under
# the `postgres_data` volume. To move major versions, dump/restore or
# `docker compose down -v` and re-ingest.
FROM postgis/postgis:15-3.4

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        postgresql-15-pgvector \
    && rm -rf /var/lib/apt/lists/*
m